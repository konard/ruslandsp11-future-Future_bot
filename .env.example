VK_GROUP_TOKEN=replace-with-group-token
# Сервисный токен приложения: им читаются стены групп и списки лайков.
VK_SERVICE_TOKEN=replace-with-service-token
# Устаревший вариант: используется, только если не задан VK_SERVICE_TOKEN.
VK_USER_TOKEN=
# Необязательно. По умолчанию используется VK_GROUP_TOKEN, чтобы отвечать от лица группы.
VK_MESSAGE_TOKEN=

FFBOT_DATABASE_PATH=data/future_bot.sqlite3
FFBOT_FF_GROUP=https://vk.ru/world_of_futuristica
FFBOT_TARGET_PEER_ID=2000000015
FFBOT_TARGET_CHAT_TITLE=Аналитика и прогнозы
FFBOT_ALLOWED_USER_IDS=199592366,1849091
# Админы, чей лайк исключает пост из отчёта. По умолчанию - FFBOT_ALLOWED_USER_IDS.
FFBOT_ADMIN_USER_IDS=
FFBOT_COMMAND_POLL_INTERVAL_SECONDS=3
# Сколько дней хранить посты в базе. Посты старше этого срока удаляются.
FFBOT_POST_RETENTION_DAYS=10
FFBOT_SCHEDULE_TIME=03:00
FFBOT_TIMEZONE=Europe/Moscow
VK_API_VERSION=5.199
# Путь к файлу доверенных сертификатов (лечит SSL: CERTIFICATE_VERIFY_FAILED).
FFBOT_VK_CA_BUNDLE=
# Проверка TLS-сертификатов VK API. Отключайте (0) только для диагностики.
FFBOT_VK_SSL_VERIFY=1
